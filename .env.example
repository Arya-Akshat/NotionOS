# NotionOS Environment Variables
# Copy this file to backend/.env and fill in your keys

GOOGLE_API_KEY=""        # Gemini — get from https://aistudio.google.com/apikey
GROQ_API_KEY=""          # Groq  — get from https://console.groq.com/keys
TAVILY_API_KEY=""        # Tavily web search API key
NOTION_API_KEY=""        # Notion integration token
NOTION_DATABASE_ID=""    # Your Notion database ID
GITHUB_TOKEN=""          # GitHub personal access token
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/notionos"
